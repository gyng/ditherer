{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "strictNullChecks": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "src",
    "paths": {
      "@src/*": ["./*"],
      "actions/*": ["actions/*"],
      "components/*": ["components/*"],
      "constants/*": ["constants/*"],
      "containers/*": ["containers/*"],
      "context/*": ["context/*"],
      "filters": ["filters/index"],
      "filters/*": ["filters/*"],
      "palettes/*": ["palettes/*"],
      "reducers/*": ["reducers/*"],
      "styles/*": ["styles/*"],
      "utils": ["utils/index"],
      "types/*": ["types/*"],
      "utils/*": ["utils/*"],
      "wasm/*": ["wasm/*"]
    }
  },
  "include": ["src"]
}
